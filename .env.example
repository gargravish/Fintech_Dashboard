# ============================================================
# FinTech Dashboard — Environment Configuration Template
# ============================================================
# Copy this file to '.env' and fill in your details.
# ============================================================

# --- Google Cloud Project ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_LOCATION=us-central1                          # BigQuery dataset location (multi-region)

# --- BigQuery ---
BQ_DATASET=aml_demo_ds
BQ_CONNECTION_ID=your-connection-id               # e.g., us-central1.__default_cloudresource_connection__

# --- Pub/Sub ---
PUBSUB_TOPIC_ID=aml-demo
PUBSUB_SUBSCRIPTION_ID=aml-demo-bq-sub

# --- Dataplex ---
DATAPLEX_LAKE_ID=aml-demo-lake
DATAPLEX_ZONE_ID=aml-demo-zone

# --- Vertex AI / Gemini ---
GEMINI_MODEL_ENDPOINT=gemini-3-flash-preview    # Model endpoint for ML.GENERATE_TEXT

# --- Frontend (Optional/Required depending on build) ---
# NEXT_PUBLIC_GCP_PROJECT_ID=your-gcp-project-id
# NEXT_PUBLIC_BQ_DATASET=aml_demo_ds
